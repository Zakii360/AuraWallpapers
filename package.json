{
    "name": "aurawallpapers",
    "version": "2.0.0",

    "description": "A modern open-source live wallpaper engine for Windows and Linux (no, you don't need Wine).",

    "author": {
        "name": "Zakii360",
        "email": "zakii@360-search.com"
    },


    "main": "main.js",


    "scripts": {

        "start": "electron .",

        "build": "electron-builder --publish never"

    },


    "dependencies": {

        "ffi-napi": "^4.0.3",

        "ref-napi": "^3.0.3"

    },


    "devDependencies": {

        "electron": "^37.10.3",

        "electron-builder": "^26.15.3"

    },


    "build": {


        "appId":
            "com.aurawallpapers.app",


        "productName":
            "AuraWallpapers",



        "icon":
            "assets/icon.png",



        "asar":
            true,



        "files": [

            "**/*"

        ],



        "directories": {


            "output":
                "release"


        },



        "publish":
            null,



        "win": {


            "target": [

                {

                    "target":
                        "nsis",

                    "arch":
                        [

                            "x64"

                        ]

                }

            ]


        },



        "nsis": {


            "oneClick":
                false,


            "allowToChangeInstallationDirectory":
                true


        },



        "linux": {


            "target": [

                "AppImage",

                "deb"

            ],



            "category":
                "Utility",



            "maintainer":
                "zakii@360-search.com",



            "synopsis":
                "Live wallpaper engine"



        }


    }

}

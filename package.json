{
  "name": "aurawallpapers",
  "version": "2.0.0",
  "description": "Open-source live wallpaper engine for Windows and Linux",

  "author": {
    "name": "AuraWallpapers Contributors",
    "email": "zakii@360-search.com"
  },

  "license": "GPL-3.0",

  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish never"
  },

  "dependencies": {
    "fs-extra": "^11.3.0"
  },

  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.15.3"
  },

  "build": {
    "appId": "com.aurawallpapers.desktop",
    "productName": "AuraWallpapers",

    "icon": "assets/icon",

    "directories": {
      "output": "release"
    },

    "files": [
      "**/*",
      "!release"
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },

    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}

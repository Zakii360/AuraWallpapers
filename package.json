{
  "name": "aurawallpapers",
  "version": "2.0.0",
  "description": "Open-source live wallpaper engine for Windows and Linux",
  "author": "AuraWallpapers Contributors",
  "license": "GPL-3.0",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },

  "dependencies": {
    "fs-extra": "^11.3.0"
  },

  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },

  "build": {

    "appId": "com.aurawallpapers.desktop",
    "productName": "AuraWallpapers",

    "directories": {
      "output": "release"
    },

    "files": [
      "**/*",
      "!release"
    ],

    "icon": "assets/icon",

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },

    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],

      "category": "Utility"
    }
  }
}

{
  "name": "aurawallpapers",
  "version": "2.0.0",

  "description": "Open-source live wallpaper engine for Windows and Linux",

  "author": {
    "name": "Zakii360",
    "email": "zakii@360-search.com"
  },


  "main": "main.js",


  "scripts": {

    "start": "electron .",

    "build": "electron-builder --publish never"

  },


  "dependencies": {

    "electron-store": "^10.0.0",

    "ffi-napi": "^4.0.3",

    "ref-napi": "^3.0.3"

  },


  "devDependencies": {

    "electron": "^37.2.0",

    "electron-builder": "^26.15.3"

  },


  "build": {


    "appId": "com.360search.aurawallpapers",

    "productName": "AuraWallpapers",


    "directories": {

      "output": "dist"

    },


    "files": [

      "**/*",

      "!node_modules/.cache",

      "!dist"

    ],


    "asar": true,


    "win": {

      "target": [

        {

          "target": "nsis",

          "arch": [

            "x64"

          ]

        }

      ],

      "icon": "assets/icon.png"

    },


    "linux": {

      "target": [

        "AppImage"

      ],

      "icon": "assets/icon.png",

      "category": "Utility"

    },


    "nsis": {

      "oneClick": false,

      "allowToChangeInstallationDirectory": true

    }


  },


  "optionalDependencies": {

    "ffi-napi": "^4.0.3",

    "ref-napi": "^3.0.3"

  }
}
